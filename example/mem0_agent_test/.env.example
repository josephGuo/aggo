# LLM 配置，必填
BaseUrl=https://your-llm-api-endpoint
APIKey=your-api-key
Model=glm-5-turbo

# mem0 配置，必填
MEM0_BASE_URL=https://your-mem0-instance.example.com
MEM0_API_KEY=your-mem0-api-key
MEM0_MODE=hosted

# 可选：如果你的 mem0 兼容接口路径或鉴权方式不同，再放开下面这些
# MEM0_AUTH_HEADER=
# MEM0_AUTH_SCHEME=
# MEM0_ADD_PATH=
# MEM0_SEARCH_PATH=

# 可选：是否把 sessionID 同步为 run_id
# MEM0_USE_SESSION_AS_RUN_ID=false
# MEM0_SEARCH_BY_SESSION=false

# 可选：业务作用域字段
# MEM0_AGENT_ID=
# MEM0_APP_ID=
# MEM0_ORG_ID=
# MEM0_PROJECT_ID=

# 可选：示例运行时固定的 user/session
# MEM0_DEMO_USER_ID=mem0-demo-user
# MEM0_DEMO_SESSION_ID=mem0-demo-session
